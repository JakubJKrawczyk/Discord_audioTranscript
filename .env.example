# =============================================================================
#  JEDYNY plik konfiguracji. Skopiuj do .env:  cp .env.example .env
#  docker-compose wstrzykuje te zmienne do wszystkich serwisów.
# =============================================================================

# --- Discord -----------------------------------------------------------------
# Token bota (WYMAGANY). https://discord.com/developers/applications
DISCORD_TOKEN=

# Prefix komend tekstowych (slash komendy "/" działają zawsze, niezależnie).
BOT_PREFIX=!

# Hasło do komendy /config (zmiana ustawień w locie). Puste = /config wyłączone.
CONFIG_PASSWORD=

# ID serwera (gildii) - slash komendy pojawiają się NATYCHMIAST po restarcie.
# Puste = sync globalny (Discord propaguje zmiany do ~1 godziny).
# Jak zdobyć: Discord > Ustawienia > Zaawansowane > Tryb dewelopera,
# potem PPM na serwerze > "Kopiuj ID serwera".
GUILD_ID=

# --- Modele AI ---------------------------------------------------------------
# Rozmiar modelu Whisper: tiny | base | small | medium | large
WHISPER_MODEL=large

# Język transkrypcji. "pl" wymusza polski; "auto" = autodetekcja Whispera.
WHISPER_LANGUAGE=pl

# Adres Ollamy (instancja na hoście, poza dockerem).
OLLAMA_API_URL=https://ollama.jakubkrawczyk.com

# Model Ollama do podsumowań. MUSI istnieć na powyższej instancji Ollama
# (sprawdź: ollama list / komenda /list_models).
OLLAMA_DEFAULT_MODEL=gemma4:e4b

# Okno kontekstu Ollamy (tokeny) dla podsumowań. Domyślne okno Ollamy jest
# małe (~2-4k) i PO CICHU obcina dłuższe transkrypty - podsumowanie pomija
# wtedy część rozmowy. num_ctx dobiera się automatycznie do długości wejścia:
#   OLLAMA_NUM_CTX     = dolna granica (minimalne okno)
#   OLLAMA_NUM_CTX_MAX = górna granica (chroni VRAM; MODEL MUSI ją wspierać)
# Większe okno = więcej VRAM. Zwiększ MAX, jeśli masz bardzo długie rozmowy
# i model o dużym kontekście (np. gemma3/deepseek obsługują 128k).
OLLAMA_NUM_CTX=8192
OLLAMA_NUM_CTX_MAX=32768

# --- Tryb automatyczny (opcjonalny) ------------------------------------------
# Kanał głosowy, na którym bot siedzi w trybie auto (ID kanału Discord).
# Zostaw puste, jeśli sterujesz botem tylko komendami /auto i /leave.
VOICE_CHANNEL_ID=
# Kanał tekstowy, gdzie bot publikuje wyniki trybu auto (ID; opcjonalny).
RESULT_CHANNEL_ID=
# Czy włączyć tryb auto od startu (wymaga VOICE_CHANNEL_ID).
AUTO_RECORD=false
# Po ilu minutach ciszy na kanale finalizować nagranie.
SILENCE_TIMEOUT_MIN=5
# Próg głośności (RMS 0-32767); poniżej = cisza (klatka odrzucana).
SILENCE_RMS_THRESHOLD=300
# Przerwa (s) rozdzielająca wypowiedzi jednej osoby (nowy znacznik czasu).
UTTERANCE_GAP_SEC=1.5
# Twardy limit długości jednej wypowiedzi (s); 0 = wyłączone.
MAX_UTTERANCE_SEC=60
# Maksymalny rozmiar ZIP wysyłanego na Discord (MB).
MAX_UPLOAD_MB=8

# --- Przechowywanie ----------------------------------------------------------
# Po ilu dniach kasować pliki audio (transkrypcje trzymane są bezterminowo).
AUDIO_RETENTION_DAYS=7

# --- API ---------------------------------------------------------------------
# Dozwolone originy CORS (np. https://moja-domena.pl). "*" = wszystkie.
ALLOWED_ORIGINS=*

# =============================================================================
#  Adres bot -> whisper-api ustawia samo compose (http://whisper-api:8000).
#  Ollama jest na hoście - jej adres podajesz wyżej w OLLAMA_API_URL.
# =============================================================================
