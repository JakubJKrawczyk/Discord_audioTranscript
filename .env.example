# =============================================================================
#  JEDYNY plik konfiguracji. Skopiuj do .env:  cp .env.example .env
#  docker-compose wstrzykuje te zmienne do wszystkich serwisów.
# =============================================================================

# --- Discord -----------------------------------------------------------------
# Token bota (WYMAGANY). https://discord.com/developers/applications
DISCORD_TOKEN=

# Prefix komend tekstowych (slash komendy "/" działają zawsze, niezależnie).
BOT_PREFIX=!

# --- Modele AI ---------------------------------------------------------------
# Rozmiar modelu Whisper: tiny | base | small | medium | large
WHISPER_MODEL=large

# Język transkrypcji. "pl" wymusza polski; "auto" = autodetekcja Whispera.
WHISPER_LANGUAGE=pl

# Adres Ollamy (instancja na hoście, poza dockerem).
OLLAMA_API_URL=https://ollama.jakubkrawczyk.com

# Model Ollama do podsumowań. MUSI istnieć na powyższej instancji Ollama
# (sprawdź: ollama list / komenda /list_models).
OLLAMA_DEFAULT_MODEL=gemma4:e4b

# --- Przechowywanie ----------------------------------------------------------
# Po ilu dniach kasować pliki audio (transkrypcje trzymane są bezterminowo).
AUDIO_RETENTION_DAYS=7

# --- API ---------------------------------------------------------------------
# Dozwolone originy CORS (np. https://moja-domena.pl). "*" = wszystkie.
ALLOWED_ORIGINS=*

# =============================================================================
#  Adres bot -> whisper-api ustawia samo compose (http://whisper-api:8000).
#  Ollama jest na hoście - jej adres podajesz wyżej w OLLAMA_API_URL.
# =============================================================================
